rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isWorkspaceMember(workspaceId) {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    function isWorkspaceAdmin(workspaceId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid)).data.role in ['admin', 'owner'];
    }


    // ─── User Profiles ────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false; // Users cannot self-delete (admin-only action)
    }

    // ─── Workspaces ───────────────────────────────────────────────────────────
    match /workspaces/{workspaceId} {
      allow read: if isWorkspaceMember(workspaceId);
      allow create: if isAuthenticated();
      allow update: if isWorkspaceAdmin(workspaceId);
      allow delete: if isWorkspaceAdmin(workspaceId);

      // Workspace members sub-collection
      match /members/{memberId} {
        allow read: if isWorkspaceMember(workspaceId);
        allow write: if isWorkspaceAdmin(workspaceId) || 
                       (isAuthenticated() && memberId == request.auth.uid && request.resource.data.role == 'owner');
      }

      // Workspace settings sub-collection
      match /settings/{settingId} {
        allow read: if isWorkspaceMember(workspaceId);
        allow write: if isWorkspaceAdmin(workspaceId);
      }
    }

    // ─── WhatsApp Accounts ────────────────────────────────────────────────────
    match /whatsappAccounts/{accountId} {
      allow read: if isAuthenticated() &&
        isWorkspaceMember(resource.data.workspaceId);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        isWorkspaceAdmin(resource.data.workspaceId);
      allow delete: if isAuthenticated() &&
        isWorkspaceAdmin(resource.data.workspaceId);
    }

    // ─── WhatsApp Messages ────────────────────────────────────────────────────
    match /whatsappMessages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if false; // Messages are immutable once sent
      allow delete: if false; // Messages cannot be deleted (audit trail)
    }

    // ─── CRM Contacts ─────────────────────────────────────────────────────────
    match /contacts/{contactId} {
      allow read: if isAuthenticated() &&
        isWorkspaceMember(resource.data.workspaceId);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        isWorkspaceMember(resource.data.workspaceId);
      allow delete: if isAuthenticated() &&
        isWorkspaceAdmin(resource.data.workspaceId);
    }

    // ─── Campaigns ────────────────────────────────────────────────────────────
    match /campaigns/{campaignId} {
      allow read: if isAuthenticated() &&
        isWorkspaceMember(resource.data.workspaceId);
      allow create: if isAuthenticated() &&
        isWorkspaceAdmin(resource.data.workspaceId);
      allow update: if isAuthenticated() &&
        isWorkspaceAdmin(resource.data.workspaceId);
      allow delete: if isAuthenticated() &&
        isWorkspaceAdmin(resource.data.workspaceId);

      // Campaign recipients sub-collection
      match /recipients/{recipientId} {
        allow read: if isAuthenticated() &&
          isWorkspaceMember(get(/databases/$(database)/documents/campaigns/$(campaignId)).data.workspaceId);
        allow write: if isAuthenticated() &&
          isWorkspaceAdmin(get(/databases/$(database)/documents/campaigns/$(campaignId)).data.workspaceId);
      }
    }

    // ─── Templates ────────────────────────────────────────────────────────────
    match /templates/{templateId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }

    // ─── AI Agents ────────────────────────────────────────────────────────────
    match /aiAgents/{agentId} {
      allow read: if isAuthenticated() &&
        isWorkspaceMember(resource.data.workspaceId);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        isWorkspaceAdmin(resource.data.workspaceId);
      allow delete: if isAuthenticated() &&
        isWorkspaceAdmin(resource.data.workspaceId);
    }

    // ─── Audit Logs (Read-only, system writes only) ───────────────────────────
    match /auditLogs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // System creates logs via server
      allow update: if false;
      allow delete: if false;
    }

    // ─── API Keys (Admin only — sensitive) ────────────────────────────────────
    match /apiKeys/{keyId} {
      allow read: if isAuthenticated() &&
        isWorkspaceAdmin(resource.data.workspaceId);
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() &&
        isWorkspaceAdmin(resource.data.workspaceId);
      allow delete: if isAuthenticated() &&
        isWorkspaceAdmin(resource.data.workspaceId);
    }

    // ─── Billing / Transactions ───────────────────────────────────────────────
    match /transactions/{txId} {
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if false; // Server-side only
      allow update: if false;
      allow delete: if false;
    }

    // ─── Catch-all: Deny everything else ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
