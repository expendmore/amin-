# ==========================================
# ExpendMore - Production Environment Configurations
# ==========================================

APP_ENV=production
APP_NAME="ExpendMore WhatsApp Marketing"
APP_URL=https://expendmore.com

# 1. Database Connection Parameters
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=expendmore
DB_USERNAME=root
DB_PASSWORD=secret_db_password

# 2. Session & Cookie Configurations
SESSION_NAME=EXPENDMORE_SESSION
SESSION_TIMEOUT=900
COOKIE_SECURE=1
COOKIE_HTTPONLY=1
COOKIE_SAMESITE=Lax

# 3. Google OAuth Consoles parameters
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://expendmore.com/auth_core/google_callback.php

# 4. SMTP mail relays credentials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-email@gmail.com
SMTP_PASSWORD=your-smtp-app-password
SMTP_SECURE=tls
SMTP_FROM_EMAIL=no-reply@expendmore.com
SMTP_FROM_NAME="ExpendMore"

# 5. Core Timezone setting
TIMEZONE="Asia/Kolkata"
DEBUG=0
